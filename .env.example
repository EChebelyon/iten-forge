# Marathon goal time (HH:MM:SS)
ITEN_FORGE_GOAL_TIME=2:50:00

# Training start date (YYYY-MM-DD), plan runs 12 weeks from this date
ITEN_FORGE_START_DATE=2026-03-09

# Pace unit: "mi" or "km"
ITEN_FORGE_UNIT=mi

# PostgreSQL (used by journal/logging features)
DATABASE_URL=postgresql://iten_forge:iten_forge@localhost:5432/iten_forge

# Twilio (for WhatsApp reminders)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
MY_WHATSAPP_NUMBER=whatsapp:+1XXXXXXXXXX
